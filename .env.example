# Copy this file to .env and fill in real secrets.
# Do not commit .env.

# ===== Logging =====
LOG_LEVEL=INFO

# ===== IBM watsonx.ai (required) =====
IBM_API_KEY=
IBM_PROJECT_ID=
IBM_CLOUD_URL=https://us-south.ml.cloud.ibm.com
IBM_MODEL_ID=openai/gpt-oss-120b

# ===== LINE Bot (required) =====
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ===== Server =====
# Flask listens on 0.0.0.0:${PORT}. Default is 8000 in rag_cli.py.
PORT=8000

# ===== Answer generation limits =====
MAX_NEW_TOKENS=120
MAX_OUTPUT_SENTENCES=1
MAX_OUTPUT_CHARS=180

# ===== Retrieval / RAG runtime =====
# These values describe the runtime retrieval behavior used by rag_cli.py.
RERANKER_ID=BAAI/bge-reranker-v2-m3
RERANKER_FALLBACK_ID=cross-encoder/ms-marco-MiniLM-L-6-v2

# ===== Knowledge ingestion / index build =====
# Used by ingest_xlsx.py.
READ_TXT=true
READ_XLSX=false
REBUILD_MODE=false
TXT_DIR=txt_docs
EXCEL_PATH=Additional information
OUT_DIR=rag_index
EMBED_MODEL=intfloat/multilingual-e5-base
BATCH=64
MAX_CHARS=800
OVERLAP=100

# ===== Brand / product images =====
# LINE image messages require publicly reachable HTTPS URLs.
BRAND_ASSET_BASE_URL=
BRAND_PREVIEW_BASE_URL=
PLACEHOLDER_IMAGE_URL=

# ===== OpenAI fallback (optional) =====
ENABLE_OPENAI_FALLBACK=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OAI_MIN_LOCAL_SCORE=0.32
OPENAI_TIMEOUT_SEC=15
OPENAI_MAX_NEW_TOKENS=220
